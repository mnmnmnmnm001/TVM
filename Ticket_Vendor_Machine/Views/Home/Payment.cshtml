
@{
    ViewBag.Title = "Payment";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Thanh Toán - Metro Ticket</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #2c3e50;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .tvm-container {
            height: 100vh;
            display: flex;
            padding: 10px;
            gap: 10px;
        }

        .side-panel {
            width: 22%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .main-panel {
            flex: 1;
            background: #85c1e9;
            border-radius: 10px;
            padding: 30px;
            color: #2c3e50;
            position: relative;
        }

        /* Payment Methods */
        .payment-option {
            background: white;
            border: 4px solid transparent;
            border-radius: 15px;
            padding: 20px;
            cursor: pointer;
            transition: 0.3s;
            height: 200px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .payment-option:hover {
                border-color: #f1c40f;
                transform: translateY(-5px);
            }

            .payment-option.active {
                border-color: #2ecc71;
                background: #e8f8f5;
            }

        .payment-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        .info-box {
            background: #d4e6f1;
            padding: 15px;
            border-radius: 8px;
            height: 100%;
            border: 2px solid #2980b9;
        }

        .price-big {
            font-size: 2rem;
            color: #e74c3c;
            font-weight: bold;
        }

        #timer {
            font-size: 1.5rem;
            font-weight: bold;
            color: #c0392b;
        }
    </style>
</head>
<body>

    <div class="tvm-container">
        <div class="side-panel" style="color:black">
            <div class="info-box text-center" style="color:black">
                <h5 class="fw-bold">THỜI GIAN CÒN LẠI</h5>
                <p id="timer">360</p>
                <hr>
                <p class="small">Vui lòng chọn phương thức thanh toán trong thời gian quy định.</p>
            </div>
        </div>

        <div class="main-panel">
            <h3 class="text-center fw-bold mb-5">CHỌN PHƯƠNG THỨC THANH TOÁN</h3>

            <div class="row g-4 justify-content-center">
                <div class="col-md-5">
                    <div class="payment-option text-center" onclick="selectPayment('Cash')">
                        <div class="payment-icon">💵</div>
                        <h4 class="fw-bold">TIỀN MẶT</h4>
                        <p class="text-muted small">CASH PAYMENT</p>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="payment-option text-center" onclick="selectPayment('QR')">
                        <div class="payment-icon">📱</div>
                        <h4 class="fw-bold">QR / NGÂN HÀNG</h4>
                        <p class="text-muted small">QR CODE / BANKING</p>
                    </div>
                </div>
            </div>

            <div class="mt-5 text-center" id="payment-instruction" style="display:none;">
                <div class="alert alert-success">
                    <h4 id="instruction-text">Vui lòng đưa tiền vào khe nhận tiền...</h4>
                </div>
            </div>
        </div>

        <div class="side-panel">
            <div class="info-box" style="color:black">
                <h5 class="fw-bold text-center">TÓM TẮT VÉ</h5>
                <hr>
                <p class="mb-1">Từ: <strong>Bến Thành</strong></p>
                <p class="mb-1">Đến: <strong>@ViewBag.ToStation</strong></p>
                <p class="mb-3">Số lượng: <strong>@ViewBag.Quantity</strong></p>

                <p class="mb-2">Loại vé: <strong>@(ViewBag.TicketTypeLabel ?? "Vé một chặng")</strong></p>
                @if((string)ViewBag.TicketType == "1day")
                {
                    <p class="mb-2 small">Hiệu lực đến: <strong>@ViewBag.ValidUntil</strong></p>
                }

                <p class="mb-0">TỔNG TIỀN:</p>
                <p class="price-big" style="color: #e74c3c; font-size: 2rem; font-weight: bold;">
                    @ViewBag.Total
                </p>

                <div class="mt-4 d-grid gap-2">
                    <button class="btn btn-warning py-3 fw-bold">XÁC NHẬN THANH TOÁN</button>

                    <button class="btn btn-danger py-2" onclick="location.href='/Home/Index'">
                        HỦY GIAO DỊCH
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let timeLeft = 360;
        const timerElement = document.getElementById('timer');

        // Đếm ngược thời gian
        const countdown = setInterval(() => {
            timeLeft--;
            timerElement.innerText = timeLeft + "s";
            if (timeLeft <= 0) {
                clearInterval(countdown);
                window.location.href = '/Home/Index';
            }
        }, 1000);

        function selectPayment(method) {
            // Highlight lựa chọn
            $('.payment-option').removeClass('active');
            event.currentTarget.classList.add('active');

            // Hiện hướng dẫn
            $('#payment-instruction').fadeIn();
            if (method === 'Cash') {
                $('#instruction-text').text("Vui lòng đưa tiền mặt vào khe nhận tiền bên dưới.");
            } else {
                $('#instruction-text').text("Vui lòng quét mã QR hiển thị trên màn hình.");
            }

            // Kích hoạt nút xác nhận
            $('#btn-confirm').removeAttr('disabled').removeClass('btn-warning').addClass('btn-success');
        }

        $('#btn-confirm').click(function () {
            alert("Đang xử lý giao dịch... Vui lòng nhận vé tại khe!");
            window.location.href = '/Home/Index';
        });
    </script>

</body>
</html>