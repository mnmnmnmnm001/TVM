
@{
    ViewBag.Title = "Payment";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Thanh Toán - Metro Ticket</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #2c3e50;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .tvm-container {
            height: 100vh;
            display: flex;
            padding: 10px;
            gap: 10px;
        }

        .side-panel {
            width: 22%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .main-panel {
            flex: 1;
            background: #85c1e9;
            border-radius: 10px;
            padding: 30px;
            color: #2c3e50;
            position: relative;
        }

        /* Payment Methods */
        .payment-option {
            background: white;
            border: 4px solid transparent;
            border-radius: 15px;
            padding: 10px;
            cursor: pointer;
            transition: 0.3s;
            height: 150px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .payment-option:hover {
                border-color: #f1c40f;
                transform: translateY(-5px);
            }

            .payment-option.active {
                border-color: #2ecc71;
                background: #e8f8f5;
            }

        .payment-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        .info-box {
            background: #d4e6f1;
            padding: 15px;
            border-radius: 8px;
            height: 100%;
            border: 2px solid #2980b9;
        }

        .price-big {
            font-size: 2rem;
            color: #e74c3c;
            font-weight: bold;
        }

        #timer {
            font-size: 1.5rem;
            font-weight: bold;
            color: #c0392b;
        }
    </style>
</head>
<body>

    <div class="tvm-container">
        <div class="side-panel" style="color:black">
            <div class="info-box text-center" style="color:black">
                <h5 class="fw-bold">THỜI GIAN CÒN LẠI</h5>
                <p id="timer">360</p>
                <hr>
                <p class="small">Vui lòng chọn phương thức thanh toán trong thời gian quy định.</p>
            </div>
        </div>

        <div class="main-panel">
            <h4 class="text-center fw-bold mb-3">CHỌN PHƯƠNG THỨC THANH TOÁN</h4>

            <div class="row g-4 justify-content-center">
                <div class="col-md-5">
                    <div class="payment-option text-center" onclick="selectPayment('Cash')">
                        <div class="payment-icon">💵</div>
                        <h4 class="fw-bold">TIỀN MẶT</h4>
                        <p class="text-muted small">CASH PAYMENT</p>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="payment-option text-center" onclick="selectPayment('QR')">
                        <div class="payment-icon">📱</div>
                        <h4 class="fw-bold">QR / NGÂN HÀNG</h4>
                        <p class="text-muted small">QR CODE / BANKING</p>
                    </div>
                </div>
            </div>


            <div class="mt-3 text-center" id="payment-instruction" style="display:none; padding:3px">
                <div class="alert alert-success">
                    <h4 id="instruction-text">Vui lòng đưa tiền vào khe nhận tiền...</h4>
                </div>
            </div>
            <div class="ticket_qr mt-2">
                <img id="qr-code" src="/images/qr.png" alt="QR Code"
                     class="img-fluid mt-3 ticket_qr_img"
                     style="display: none; max-width: 400px; max-height: 350px; margin: 0 auto;">

                <div id="qr-text" class="mt-2 large text-muted text-center" style="display:none">
                    Quét mã QR để thanh toán
                </div>
            </div>
        </div>

        <div class="side-panel">
            <div class="info-box" style="color:black">
                <h5 class="fw-bold text-center">TÓM TẮT VÉ</h5>
                <hr>
                <p class="mb-1">Từ: <strong>Bến Thành</strong></p>
                <p class="mb-1">Đến: <strong>@ViewBag.ToStation</strong></p>
                <p class="mb-3">Số lượng: <strong>@ViewBag.Quantity</strong></p>

                <p class="mb-2">Loại vé: <strong>@(ViewBag.TicketTypeLabel ?? "Vé một chặng")</strong></p>
                <p class="mb-2 small">Hiệu lực đến: <strong>@ViewBag.ValidUntil</strong></p>
                @*@if((string)ViewBag.TicketType == "1day")
                {
                }*@

                <p class="mb-0">TỔNG TIỀN:</p>
                <p class="price-big" style="color: #e74c3c; font-size: 2rem; font-weight: bold;">
                    @ViewBag.Total
                </p>

                <div class="mt-4 d-grid gap-2">
                    <button class="btn btn-warning py-3 fw-bold" id="btn-confirm" disabled>XÁC NHẬN THANH TOÁN</button>

                    <button class="btn btn-danger py-2" onclick="location.href='/Home/Index'">
                        HỦY GIAO DỊCH
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let timeLeft = 360;
        const timerElement = document.getElementById('timer');

        // Đếm ngược thời gian
        const countdown = setInterval(() => {
            timeLeft--;
            timerElement.innerText = timeLeft + "s";
            if (timeLeft <= 0) {
                clearInterval(countdown);
                window.location.href = '/Home/Index';
            }
        }, 1000);

        let qrTimeout;
        // Lấy dữ liệu từ ViewBag
        let ticketId = '@ViewBag.TicketType';
        let ticketQty = '@ViewBag.Quantity';
        let ticketTotal = '@ViewBag.Total';
        let ticketStation = '@ViewBag.ToStation';
        let stEN = '@ViewBag.StEN';

        let myBank = {
            BANK_ID: "TPB",
            ACCOUNT_NO: "00001756255",
        }

        function selectPayment(method) {
            clearTimeout(qrTimeout);
            $('.payment-option').removeClass('active');
            if (window.event) {
                $(window.event.currentTarget).addClass('active');
            }
            let rawAmount = ticketTotal.replace(/\D/g, '');

            let info = encodeURIComponent(`${ticketId}_${ticketQty}_${stEN}`);

            let qrUrl = `https://img.vietqr.io/image/${myBank.BANK_ID}-${myBank.ACCOUNT_NO}-compact2.png?amount=${rawAmount}&addInfo=${info}`;
            const qrImg = $('#qr-code');
            const qrText = $('#qr-text');
            const instructionBox = $('#payment-instruction');
            const btnConfirm = $('#btn-confirm');

            if (method === 'Cash') {
                $('#instruction-text').fadeIn();
                qrImg.hide();
                qrText.hide();

                instructionBox.stop(true, true).fadeIn();
                $('#instruction-text').text("Vui lòng đưa tiền mặt vào khe nhận tiền bên dưới.");

                btnConfirm
                    .prop('disabled', false)
                    .removeClass('btn-warning')
                    .addClass('btn-success');
            }
            else if (method === 'QR') {
                qrImg.attr('src', qrUrl);
                instructionBox.hide();

                qrTimeout = setTimeout(() => {
                    console.log(ticketId);
                    qrImg.css('display', 'block').hide().stop(true, true).fadeIn();
                    qrText.stop(true, true).fadeIn();
                    $('#instruction-text').hide();
                }, 2000);


                btnConfirm
                    .prop('disabled', true)
                    .removeClass('btn-success')
                    .addClass('btn-warning');



                //setTimeout(() => {
                //    alert("Thanh toán thành công qua QR!");
                //    btnConfirm.prop('disabled', false).addClass('btn-success');
                //}, 3000);
            }
        }

        document.getElementById('btn-confirm').onclick = function () {
            const toStation = '@ViewBag.ToStation';
            const qty = '@ViewBag.Quantity';
            const total = '@ViewBag.Total';

            const generateUrl = `/Home/Generate?toStation=${encodeURIComponent(toStation)}&qty=${qty}&total=${encodeURIComponent(total)}`;

            window.open(generateUrl, '_blank');

            window.location.href = '/Home/Index';
        };


    </script>

</body>
</html>