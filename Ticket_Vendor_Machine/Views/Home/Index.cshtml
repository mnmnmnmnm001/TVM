            <button class="btn-menu">TRẢ LẠI VÉ<br /><small>REFUND</small></button>

            <div class="lang-switch">
                <button class="btn btn-light btn-sm">VN</button>
                <button class="btn btn-outline-light btn-sm">EN</button>
            </div>
        </div>

        <div class="main-panel">
            <h4 class="text-center fw-bold">CHỌN GA ĐẾN / SELECT DESTINATION</h4>
            <p class="text-center mb-0">Ga khởi hành: <strong>Bến Thành</strong></p>

            <div class="station-grid" id="stationList">
            </div>

