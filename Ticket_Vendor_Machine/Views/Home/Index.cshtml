﻿@{
    ViewBag.Title = "Metro Ticket Vending Machine";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Metro TVM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #2c3e50;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .tvm-container {
            height: 100vh;
            display: flex;
            padding: 10px;
            gap: 10px;
        }

        .side-panel {
            width: 20%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .btn-menu {
            background: #ecf0f1;
            color: #2c3e50;
            border: none;
            padding: 15px 10px;
            font-weight: bold;
            border-radius: 5px;
            text-align: left;
        }

            .btn-menu.active {
                background: #f1c40f;
            }
        /* Màu vàng đặc trưng của máy bán vé */
        .main-panel {
            flex: 1;
            background: #85c1e9;
            border-radius: 10px;
            padding: 20px;
            color: #2c3e50;
            position: relative;
        }

        .station-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 20px;
            max-height: 60vh;
            overflow-y: auto;
        }

        .btn-station {
            background: white;
            border: 2px solid #2980b9;
            padding: 10px;
/*            border-radius: 0px;*/
            font-weight: bold;
        }

            .btn-station.selected-to {
                background: #e74c3c !important;
                color: white !important;
            }

        .info-box {
            background: #d4e6f1;
            padding: 15px;
            border-radius: 5px;
            height: 100%;
            border: 2px solid #2980b9;
        }

        .price-text {
            font-size: 1.5rem;
            color: #e74c3c;
            font-weight: bold;
        }

        .lang-switch {
            position: absolute;
            bottom: 10px;
            left: 10px;
        }
    </style>
</head>
<body>

    <div class="tvm-container">
        <div class="side-panel">
            <button class="btn-menu" id="menu-buy">MUA VÉ</button>
            <button class="btn-menu active" id="menu-sjt">VÉ MỘT CHẶNG</button>
            <button class="btn-menu" id="menu-refund">TRẢ LẠI VÉ</button>

            <div class="lang-switch">
                <button class="btn btn-lang btn-light btn-sm" data-lang="vn">VN</button>
                <button class="btn btn-lang btn-outline-light btn-sm" data-lang="en">EN</button>
            </div>
        </div>

        <div class="main-panel">
            <h4 id="lbl-title" class="text-center fw-bold">CHỌN GA ĐẾN</h4>
            <p class="text-center mb-0"><span id="lbl-start">Ga khởi hành:</span> <strong class="start">Bến Thành</strong></p>

            <div class="station-grid" id="stationList">
            </div>

            <div class="mt-5 text-center">
                <button class="btn btn-primary btn-lg px-5" id="btn-next">TIẾP THEO</button>
                <button class="btn btn-danger btn-lg px-5" id="btn-cancell">HỦY</button>
            </div>
        </div>

        <div class="side-panel" style="color:black">
            <div class="info-box">
                <p class="mb-1"><span id="lbl-ticket-type">Loại vé:</span> <strong id="val-ticket-type">Vé một chặng</strong></p>
                <hr class="my-2">
                <p class="mb-1 small"><span id="lbl-from">Từ:</span> <strong class="start">Bến Thành</strong></p>
                <p class="mb-3 small"><span id="lbl-to">Đến:</span> <strong id="txtTo">---</strong></p>

                <p class="mb-1 small">
                    <span id="lbl-quantity-display">Số lượng:</span>
                    <div class="d-flex align-items-center mt-1 mb-3">
                        <button class="btn btn-sm btn-outline-secondary px-2" id="btn-minus">-</button>
                        <strong id="txtQty" class="mx-3 fs-5">1</strong>
                        <button class="btn btn-sm btn-outline-secondary px-2" id="btn-plus">+</button>
                    </div>
                </p>

                <p class="mb-0" id="lbl-unit-price-label">Đơn giá:</p>
                <p class="price-text" id="txtUnitPrice">0 VNĐ</p>

                <p class="mb-0" id="lbl-total-price-label">Tổng giá vé:</p>
                <p class="price-text" id="txtTotal">0 VNĐ</p>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
    let currentLang = 'vn';
    let selectedDestId = null;
    let currentQty = 1;

    const stations = [
        { id: 2,  nameVN: "Nhà hát TP",       nameEN: "Opera House" },
        { id: 3,  nameVN: "Ba Son",             nameEN: "Ba Son" },
        { id: 4,  nameVN: "Văn Thánh",          nameEN: "Van Thanh Park" },
        { id: 5,  nameVN: "Tân Cảng",           nameEN: "Tan Cang" },
        { id: 6,  nameVN: "Thảo Điền",          nameEN: "Thao Dien" },
        { id: 7,  nameVN: "An Phú",             nameEN: "An Phu" },
        { id: 8,  nameVN: "Rạch Chiếc",         nameEN: "Rach Chiec" },
        { id: 9,  nameVN: "Phước Long",         nameEN: "Phuoc Long" },
        { id: 10, nameVN: "Bình Thái",          nameEN: "Binh Thai" },
        { id: 11, nameVN: "Thủ Đức",            nameEN: "Thu Duc" },
        { id: 12, nameVN: "Khu CN cao",         nameEN: "High-Tech Park" },
        { id: 13, nameVN: "ĐHQG",               nameEN: "National University" },
        { id: 14, nameVN: "Bến xe Suối Tiên",   nameEN: "Suoi Tien Terminal" }
    ];

    function formatVND(amount) {
        return amount.toLocaleString('vi-VN') + ' VNĐ';
    }

    function fetchAndDisplayFare() {
        if (!selectedDestId) return;

        $.ajax({
            url: '@Url.Action("CalculateFare", "Home")',
            type: 'GET',
            data: { destinationId: selectedDestId, quantity: currentQty },
            success: function (result) {
                $('#txtUnitPrice').text(formatVND(result.unitFare));
                $('#txtTotal').text(formatVND(result.totalFare));
                $('#btn-next').prop('disabled', false);
            },
            error: function () {
                $('#txtUnitPrice').text('Lỗi / Error');
                $('#txtTotal').text('Lỗi / Error');
            }
        });
    }

    function renderStations() {
        $('#stationList').empty();
        stations.forEach(function (s) {
            const name = (currentLang === 'vn') ? s.nameVN : s.nameEN;
            const selected = (s.id === selectedDestId) ? 'selected-to' : '';
            $('#stationList').append(
                `<button class="btn-station ${selected}" data-id="${s.id}" data-name="${name}">
                     ${s.id}. ${name}
                 </button>`
            );
        });
    }

    function updateStaticText() {
        if (currentLang === 'en') {
            $('#lbl-title').text('SELECT DESTINATION');
            $('#lbl-start').text('Departure:');
            $('#btn-next').text('NEXT');
            $('#btn-cancell').text('CANCEL');
            $('#menu-sjt').text('Single Journey Ticket')
            $('#lbl-ticket-type').text('Ticket Type:');
            $('#val-ticket-type').text('Single Journey Ticket');
            $('#lbl-from').text('From:');
            $('#lbl-to').text('To:');
            $('#lbl-quantity-display').text('Quantity:');
            $('#lbl-unit-price-label').text('Unit Price:');
            $('#lbl-total-price-label').text('Total Fare:');
            $('#menu-buy').html('BUY TICKET');
            $('#menu-refund').html('REFUND');
            $('.start').text('Ben Thanh');
        } else {
            $('#lbl-title').text('CHỌN GA ĐẾN');
            $('#lbl-start').text('Ga khởi hành:');
            $('#btn-next').text('TIẾP THEO');
            $('#btn-cancell').text('HỦY');
            $('#lbl-ticket-type').text('Loại vé:');
            $('#val-ticket-type').text('Vé một chặng');
            $('#lbl-from').text('Từ:');
            $('#lbl-to').text('Đến:');
            $('#lbl-quantity-display').text('Số lượng:');
            $('#lbl-unit-price-label').text('Đơn giá:');
            $('#lbl-total-price-label').text('Tổng giá vé:');
            $('#menu-buy').html('MUA VÉ');
            $('#menu-refund').html('TRẢ LẠI VÉ');
            $('.start').text('Bến Thành');
        }
    }

    $(document).ready(function () {
        renderStations();

        // Language switch
        $('.btn-lang').click(function () {
            $('.btn-lang').removeClass('btn-light').addClass('btn-outline-light');
            $(this).addClass('btn-light').removeClass('btn-outline-light');
            currentLang = $(this).data('lang');
            renderStations();
            updateStaticText();
            if (selectedDestId) {
                const s = stations.find(x => x.id === selectedDestId);
                if (s) $('#txtTo').text(currentLang === 'vn' ? s.nameVN : s.nameEN);
            }
        });

        // Select destination station
        $(document).on('click', '.btn-station', function () {
            selectedDestId = parseInt($(this).data('id'));
            $('.btn-station').removeClass('selected-to');
            $(this).addClass('selected-to');
            $('#txtTo').text($(this).data('name'));
            currentQty = 1;
            $('#txtQty').text('1');
            fetchAndDisplayFare();  // calls HomeController.CalculateFare/ HomeController uses ServiceFunction/CalculateFare.cs (class function)
        });

        // Quantity minus
        $('#btn-minus').click(function () {
            if (currentQty > 1) {
                currentQty--;
                $('#txtQty').text(currentQty);
                fetchAndDisplayFare();
            }
        });

        // Quantity plus (max 9) muon gioi han max bao nhieu thi chinh o day
        $('#btn-plus').click(function () {
            if (currentQty < 9) {
                currentQty++;
                $('#txtQty').text(currentQty);
                fetchAndDisplayFare();
            }
        });

        // Cancel
        $('#btn-cancell').click(function () {
            selectedDestId = null;
            currentQty = 1;
            $('#txtQty').text('1');
            $('#txtTo').text('---');
            $('#txtUnitPrice').text('0 VNĐ');
            $('#txtTotal').text('0 VNĐ');
            $('#btn-next').prop('disabled', true);
            $('.btn-station').removeClass('selected-to');
        });

        $('#btn-next').click(function () {
            // 1. Kiểm tra nếu người dùng chưa chọn ga
            if (!selectedDestId || $('#txtTo').text() === '---') {
                const msg = (currentLang === 'vn') ? "Vui lòng chọn ga đến!" : "Please select destination!";
                alert(msg);
                return;
            }

            // 2. Lấy dữ liệu hiện tại từ giao diện
            const toStation = $('#txtTo').text();
            const qty = currentQty;
            const total = $('#txtTotal').text();

            // 3. Chuyển hướng sang Action Payment trong HomeController
            // Dữ liệu sẽ được truyền qua Query String (?key=value)
            window.location.href = `/Home/Payment?toStation=${encodeURIComponent(toStation)}&qty=${qty}&total=${encodeURIComponent(total)}`;
        });
    });
    </script>
</body>
</html>