            </div>
        </div>

        <div class="side-panel">
            <div class="info-box">
                <p class="mb-1">Loại vé: <strong>Vé một chặng</strong></p>
                <hr class="my-2">
                <p class="mb-1 small">Từ: <strong>Bến Thành</strong></p>
                <p class="mb-3 small">Đến: <strong id="txtTo">---</strong></p>

                <p class="mb-0">Đơn giá:</p>
                <p class="price-text" id="txtUnitPrice">0 VNĐ</p>

