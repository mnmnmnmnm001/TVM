    <script>
    // Dữ liệu giả lập lấy từ Database của bạn
    const stations = [
        { id: 2, name: "Nhà hát TP" }, { id: 3, name: "Ba Son" },
        { id: 4, name: "Văn Thánh" }, { id: 5, name: "Tân Cảng" },
        { id: 6, name: "Thảo Điền" }, { id: 7, name: "An Phú" },
        { id: 8, name: "Rạch Chiếc" }, { id: 9, name: "Phước Long" },
        { id: 10, name: "Bình Thái" }, { id: 11, name: "Thủ Đức" },
        { id: 12, name: "Khu CN cao" }, { id: 13, name: "ĐHQG" },
        { id: 14, name: "Suối Tiên" }
    ];

    $(document).ready(function() {
        // Render danh sách ga
        stations.forEach(s => {
            $('#stationList').append(`<button class="btn-station" data-id="${s.id}" data-name="${s.name}">${s.id}. ${s.name}</button>`);
        });

        // Sự kiện chọn ga
        $('.btn-station').click(function() {
            $('.btn-station').removeClass('selected-to');
            $(this).addClass('selected-to');

            const name = $(this).data('name');
            $('#txtTo').text(name);

            // Logic tính tiền tạm thời (Bạn sẽ gọi API từ Controller tại đây)
           const destId = $(this).data('id');

            $.get('@Url.Action("CalculateFare", "Home")', { destinationId: destId }, function(result) {
                const formatted = result.fare.toLocaleString('vi-VN') + ' VNĐ';
                $('#txtUnitPrice').text(formatted);
                $('#txtTotal').text(formatted);
            });
        });
    });


    </script>

