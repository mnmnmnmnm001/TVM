<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Metro Ticket Vending Machine</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #2c3e50;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        .tvm-container {
            height: 100vh;
            display: flex;
            padding: 10px;
            gap: 10px;
        }

        /* Cột trái & phải */
        .side-panel {
            width: 20%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .btn-menu {
            background: #ecf0f1;
            color: #2c3e50;
            border: none;
            padding: 15px 10px;
            font-weight: bold;
            border-radius: 5px;
            text-align: left;
            font-size: 0.9rem;
        }

            .btn-menu.active {
                background: #f1c40f;
            }

        /* Cột giữa */
        .main-panel {
            flex: 1;
            background: #85c1e9;
            border-radius: 10px;
            padding: 20px;
            color: #2c3e50;
            position: relative;
        }

        .station-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

        .btn-station {
            background: white;
            border: 2px solid #2980b9;
            padding: 10px;
            border-radius: 20px;
            font-weight: bold;
        }

            .btn-station.selected-from {
                background: #f1c40f;
                color: black;
            }

            .btn-station.selected-to {
                background: #e74c3c;
                color: white;
            }

        /* Panel thanh toán bên phải */
        .info-box {
            background: #d4e6f1;
            padding: 15px;
            border-radius: 5px;
            height: 100%;
            border: 2px solid #2980b9;
        }

        .price-text {
            font-size: 1.5rem;
            color: #e74c3c;
            font-weight: bold;
        }

        .footer-controls {
            position: absolute;
            bottom: 20px;
            width: 90%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .lang-switch {
            position: absolute;
            bottom: 10px;
            left: 10px;
        }
    </style>
</head>
<body>

    <div class="tvm-container">
        <div class="side-panel">
            <button class="btn-menu">MUA VÉ<br /><small>BUY TICKET</small></button>
            <button class="btn-menu active">VÉ MỘT CHẶNG<br /><small>(SJT)</small></button>
            @*<button class="btn-menu" disabled style="opacity:0.5">VÉ 1 NGÀY (N/A)</button>*@
