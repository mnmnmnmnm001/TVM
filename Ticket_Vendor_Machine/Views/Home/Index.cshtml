@{
    ViewBag.Title = "Metro Ticket Vending Machine";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Metro TVM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #2c3e50;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .tvm-container {
            height: 100vh;
            display: flex;
            padding: 10px;
            gap: 10px;
        }

        .side-panel {
            width: 20%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .btn-menu {
            width: 100%;
            display: block;
        }

        .btn-menu {
            background: #ecf0f1;
            color: #2c3e50;
            border: none;
            padding: 15px 10px;
            font-weight: bold;
            border-radius: 5px;
            text-align: left;
        }

            .btn-menu.active {
                background: #f1c40f;
            }
        /* Màu vàng đặc trưng của máy bán vé */
        .main-panel {
            flex: 1;
            background: #85c1e9;
            border-radius: 10px;
            padding: 20px;
            color: #2c3e50;
            position: relative;
        }

        .station-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 20px;
            max-height: 60vh;
            overflow-y: auto;
        }

        .btn-station {
            background: white;
            border: 2px solid #2980b9;
            padding: 10px;
            font-weight: bold;
        }

            .btn-station.selected-to {
                background: #e74c3c !important;
                color: white !important;
            }

        .info-box {
            background: #d4e6f1;
            padding: 15px;
            border-radius: 5px;
            height: 100%;
            border: 2px solid #2980b9;
        }

        .price-text {
            font-size: 1.5rem;
            color: #e74c3c;
            font-weight: bold;
        }

        .lang-switch {
            position: absolute;
            bottom: 10px;
            left: 10px;
        }
    </style>
</head>
<body>

    <div class="tvm-container">
        <div class="side-panel">
            <div>
                <button class="btn-menu active mb-2" data-type="single" id="txt1">VÉ MỘT CHẶNG</button>
                <button class="btn-menu mb-2" data-type="1day" id="txt2">VÉ MỘT NGÀY</button>
            </div>

            <div class="lang-switch">
                <button class="btn btn-lang btn-light btn-sm" data-lang="vn">VN</button>
                <button class="btn btn-lang btn-outline-light btn-sm" data-lang="en">EN</button>
            </div>
        </div>

        <div class="main-panel">
            <h4 id="lbl-title" class="text-center fw-bold">CHỌN GA ĐẾN</h4>
            <p class="text-center mb-0"><span id="lbl-start">Ga khởi hành:</span> <strong class="start">Bến Thành</strong></p>

            <div class="station-grid" id="stationList">
            </div>

            <div class="mt-5 text-center">
                <button class="btn btn-primary btn-lg px-5" id="btn-next" disabled>TIẾP THEO</button>
                <button class="btn btn-danger btn-lg px-5" id="btn-cancell">HỦY</button>
            </div>
        </div>

        <div class="side-panel" style="color:black">
            <div class="info-box">
                <p class="mb-1"><span id="lbl-ticket-type">Loại vé:</span> <strong id="val-ticket-type"></strong></p>
                <hr class="my-2">
                <p class="mb-1 small"><span id="lbl-from">Từ:</span> <strong class="start">Bến Thành</strong></p>
                <p class="mb-3 small"><span id="lbl-to">Đến:</span> <strong id="txtTo">---</strong></p>

                <p class="mb-1 small">
                    <span id="lbl-quantity-display">Số lượng:</span>
                    <div class="d-flex align-items-center mt-1 mb-3">
                        <button class="btn btn-sm btn-outline-secondary px-2" id="btn-minus">-</button>
                        <strong id="txtQty" class="mx-3 fs-5">1</strong>
                        <button class="btn btn-sm btn-outline-secondary px-2" id="btn-plus">+</button>
                    </div>
                </p>

                <p class="mb-0" id="lbl-unit-price-label">Đơn giá:</p>
                <p class="price-text" id="txtUnitPrice">0 VNĐ</p>

                <p class="mb-0" id="lbl-total-price-label">Tổng giá vé:</p>
                <p class="price-text" id="txtTotal">0 VNĐ</p>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
    let currentLang = 'vn';
    let selectedDestId = null;
    let currentQty = 1;
    let currentTicketType = 'single';
    const stations = [
        { id: 2,  nameVN: "Nhà hát Thành Phố",       nameEN: "Opera House" },
        { id: 3,  nameVN: "Ba Son",             nameEN: "Ba Son" },
        { id: 4,  nameVN: "Văn Thánh",          nameEN: "Van Thanh Park" },
        { id: 5,  nameVN: "Tân Cảng",           nameEN: "Tan Cang" },
        { id: 6,  nameVN: "Thảo Điền",          nameEN: "Thao Dien" },
        { id: 7,  nameVN: "An Phú",             nameEN: "An Phu" },
        { id: 8,  nameVN: "Rạch Chiếc",         nameEN: "Rach Chiec" },
        { id: 9,  nameVN: "Phước Long",         nameEN: "Phuoc Long" },
        { id: 10, nameVN: "Bình Thái",          nameEN: "Binh Thai" },
        { id: 11, nameVN: "Thủ Đức",            nameEN: "Thu Duc" },
        { id: 12, nameVN: "Khu Công Nghệ Cao",         nameEN: "High-Tech Park" },
        { id: 13, nameVN: "Đại Học Quốc Gia",               nameEN: "National University" },
        { id: 14, nameVN: "Bến xe Suối Tiên",   nameEN: "Suoi Tien Terminal" }
    ];

    function formatVND(amount) {
        return amount.toLocaleString('vi-VN') + ' VNĐ';
    }

    function fetchAndDisplayFare() {
        const destParam = selectedDestId || 0;

        $.ajax({
            url: '@Url.Action("CalculateFare", "Home")',
            type: 'GET',
            data: { destinationId: destParam, quantity: currentQty, ticketType: currentTicketType },
            success: function (result) {
                $('#txtUnitPrice').text(formatVND(result.unitFare));
                $('#txtTotal').text(formatVND(result.totalFare));
                $('#btn-next').prop('disabled', false);
            },
            error: function () {
                $('#txtUnitPrice').text('Lỗi / Error');
                $('#txtTotal').text('Lỗi / Error');
            }
        });
    }

    function renderStations() {
        $('#stationList').empty();
        stations.forEach(function (s) {
            const name = (currentLang === 'vn') ? s.nameVN : s.nameEN;
            const selected = (s.id === selectedDestId) ? 'selected-to' : '';
            $('#stationList').append(
                `<button class="btn-station ${selected}" data-id="${s.id}" data-name="${name}">
                     ${s.id}. ${name}
                 </button>`
            );
        });
    }

    function updateStaticText() {
        let ticketName = "";
        if (currentTicketType === '1day') {
            ticketName = (currentLang === 'vn') ? 'VÉ MỘT NGÀY' : 'One Day Ticket';
        } else {
            ticketName = (currentLang === 'vn') ? 'VÉ MỘT CHẶNG' : 'Single Journey Ticket';
        }
        $('#val-ticket-type').text(ticketName);

        if (currentLang === 'en') {
            $('#lbl-title').text(currentTicketType === '1day' ? 'ONE DAY TICKET' : 'SELECT DESTINATION');
            $('#lbl-start').text('Departure:');
            $('#btn-next').text('NEXT');
            $('#btn-cancell').text('CANCEL');
            $('#txt1').text('Single Journey Ticket');
            $('#txt2').text('One Day Journey Ticket');
            $('.start').text('Ben Thanh');
        } else {
            $('#lbl-title').text(currentTicketType === '1day' ? 'VÉ MỘT NGÀY' : 'CHỌN GA ĐẾN');
            $('#lbl-start').text('Ga khởi hành:');
            $('#btn-next').text('TIẾP THEO');
            $('#btn-cancell').text('HỦY');
            $('#txt1').text('VÉ MỘT CHẶNG');
            $('#txt2').text('VÉ MỘT NGÀY');
            $('.start').text('Bến Thành');
        }

        if (currentTicketType === '1day') {
            $('#stationList').hide();
            $('#txtTo').text(ticketName);
            $('#btn-next').prop('disabled', false);
            fetchAndDisplayFare();
        } else {
            $('#stationList').show();
            if (selectedDestId) {
                const s = stations.find(x => x.id === selectedDestId);
                if (s) $('#txtTo').text(currentLang === 'vn' ? s.nameVN : s.nameEN);
            } else {
                $('#txtTo').text('---');
                $('#txtUnitPrice').text('0 VNĐ');
                $('#txtTotal').text('0 VNĐ');
                $('#btn-next').prop('disabled', true);
            }
        }
    }

    $(document).ready(function () {
        updateStaticText();
        renderStations();

        $(document).on('click', '.btn-menu[data-type]', function () {
            $('.btn-menu[data-type]').removeClass('active');
            $(this).addClass('active');

            currentTicketType = $(this).data('type');

            if (currentTicketType === '1day') {
                selectedDestId = null;
                $('.btn-station').removeClass('selected-to');
                $('#txtQty').text('1');
                currentQty = 1;
            } else {
                $('#txtTo').text('---');
                $('#txtUnitPrice').text('0 VNĐ');
                $('#txtTotal').text('0 VNĐ');
                $('#btn-next').prop('disabled', true);
            }

            updateStaticText();
        });

        $('.btn-lang').click(function () {
            $('.btn-lang').removeClass('btn-light').addClass('btn-outline-light');
            $(this).addClass('btn-light').removeClass('btn-outline-light');
            currentLang = $(this).data('lang');

            renderStations();
            updateStaticText();
        });

        $(document).on('click', '.btn-station', function () {
            if (currentTicketType === '1day') return;
            selectedDestId = parseInt($(this).data('id'));
            $('.btn-station').removeClass('selected-to');
            $(this).addClass('selected-to');
            $('#txtTo').text($(this).data('name'));
            currentQty = 1;
            $('#txtQty').text('1');
            fetchAndDisplayFare();
        });

        $('#btn-minus').click(function () {
            if (currentQty > 1) {
                currentQty--;
                $('#txtQty').text(currentQty);
                fetchAndDisplayFare();
            }
        });

        $('#btn-plus').click(function () {
            if (currentQty < 9) {
                currentQty++;
                $('#txtQty').text(currentQty);
                fetchAndDisplayFare();
            }
        });

        $('#btn-cancell').click(function () {
            selectedDestId = null;
            currentQty = 1;
            $('#txtQty').text('1');
            $('#txtTo').text('---');
            $('#txtUnitPrice').text('0 VNĐ');
            $('#txtTotal').text('0 VNĐ');
            $('#btn-next').prop('disabled', true);
            $('.btn-station').removeClass('selected-to');
            $('#stationList').show();
        });

        $('#btn-next').click(function () {

            if (currentTicketType === '1day') {
                const ticketName = $('#val-ticket-type').text();
                const qty = currentQty;
                const total = $('#txtTotal').text();
                const stEN = 'ONE_DAY';
                window.location.href = `/Home/Payment?toStation=${encodeURIComponent(ticketName)}&qty=${qty}&total=${encodeURIComponent(total)}&ticketType=${encodeURIComponent(currentTicketType)}&stEN=${stEN}`;
                return;
            }

            if (!selectedDestId || $('#txtTo').text() === '---') {
                const msg = (currentLang === 'vn') ? "Vui lòng chọn ga đến!" : "Please select destination!";
                alert(msg);
                return;
            }

            const toStation = $('#txtTo').text();
            const qty = currentQty;
            const total = $('#txtTotal').text();
            const selectedStation = stations.find(s => s.id === selectedDestId);
            const stEN = selectedStation ? selectedStation.nameEN.replace(/\s+/g, '_') : "Unknown";

            window.location.href = `/Home/Payment?toStation=${encodeURIComponent(toStation)}&qty=${qty}&total=${encodeURIComponent(total)}&ticketType=${encodeURIComponent(currentTicketType)}&stEN=${stEN}`;
        });
    });

    </script>
</body>
</html>