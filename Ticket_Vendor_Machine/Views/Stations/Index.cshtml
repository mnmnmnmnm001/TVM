        <td>
            @Html.DisplayFor(modelItem => item.NameVN)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.NameEN)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.StationOrder)
        </td>
